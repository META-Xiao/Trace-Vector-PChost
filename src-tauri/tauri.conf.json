{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "trace-vector-pchost",
  "version": "0.1.0",
  "identifier": "com.tracevector.pchost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Trace Vector PC Host",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "shadow": true,
        "theme": "Auto"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "nsis": {
      "installMode": "currentUser",
      "allowDowngrades": true
    }
  }
}
